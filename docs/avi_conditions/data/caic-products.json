F7","DAFC9825-B67E-4FF5-8E6C-4D05CC20E554","DBC40A27-66D6-4C9D-927E-1D5F05092F1A","E431262C-0AE0-4E4B-9DA4-A2E35B49E671","E687FCD9-066C-4E47-8B6C-164C1B586A18","E72F7052-876D-476F-89A0-9AEE369F0317","EC9276F5-8C4A-431C-882B-4BA90A9D8881","ECA6DAA1-1E5C-4D1F-8186-B9969A5E9EAD","ED5C21DE-D335-4D82-85CF-485CD449C602","EEF9E8C9-3899-4E76-8A11-C2265812FA53","F2A935D9-8E28-4421-8382-837E3E0E99B7","FCDD2204-2B10-4061-8CDF-928C5DE4C24D","FD36A9C3-DDBD-43BF-BA4B-AE2D2C8CA87F","FE996429-CEFA-41FC-8228-3E4661406DDF"],"areaId":"5662aefc404ad01d6aefae3a9bb3f4bda3845e336b6c6011d46f75ddc7bbe57f","forecaster":"Chris Dickson","issueDateTime":"2026-05-19T22:30:00Z","expiryDateTime":"2026-05-20T22:30:00Z","isTranslated":false,"isAutoTranslated":false,"isMultiDay":false,"timezone":"America\/Denver","weatherSummary":{"days":[]},"snowpackSummary":{"days":[]},"avalancheSummary":{"days":[{"date":"2026-05-20T22:30:00Z","content":"<p>Most slopes are safe from avalanches, but recent snowfall means you could find small wind-drifted slabs in isolated alpine terrain, especially below ridgelines and in the tops of gullies and couloirs. If you find more than 6 inches of fresh snow, assess the stiffness of the new snow and look for cracking before committing to steep, consequential terrain. Even a small pocket of unstable snow can be enough to knock you off your feet and take you for a ride.<\/p><p>When sunny skies return, expect the recent snow to quickly get wet and shed off very steep slopes as mostly small, loose wet avalanches. These will mostly be harmless unless they push you into rocks, creeks, or over cliffs.<\/p>"}]},"terrainAndTravelAdvice":{"days":[[],[],[]]},"communication":{"headline":"","sms":""},"media":{"Images":[{"id":"5c3eedf9-e34b-4341-89fc-ecc76b1e5053","url":"http:\/\/res.cloudinary.com\/dozsqvbas\/image\/upload\/v1779222269\/AvIDfx\/odgg4xqymspxzkscpra1.webp","width":2500,"height":1875,"credit":"","caption":"<p>New snow from May 18th has temporarily changed the look of the mountains. In the short term, this new snow means there is once again potential for small pockets of wind-drifted snow in the alpine. And in the long term, when the late-May sunshine returns, we can expect another round of small, wet, loose avalanches on steep, sunny slopes. <\/p>","tag":"avalanche","altText":"Fresh snow on trees. ","dateTaken":"2026-05-18T17:17:56Z","isArchived":false},{"id":"3c34221f-b854-4753-a100-e3d5aa18cfee","url":"http:\/\/res.cloudinary.com\/dozsqvbas\/image\/upload\/v1778787616\/AvIDfx\/lo1ei30iqxublng93aed.webp","width":1816,"height":3550,"credit":"C","caption":"<p>As more and more rocks show up in the start zones of avalanche paths we can expected to see continued wet avalanche activity when warmer temperatures return later this week. <\/p>","tag":"avalanche","altText":"wet avalanches coming out of steep rocky terrain","dateTaken":"2026-05-13T19:13:03Z","isArchived":false},{"id":"7dc6e56a-0d82-4cea-a2c1-4e853b6695d1","url":"http:\/\/res.cloudinary.com\/dozsqvbas\/image\/upload\/v1778770482\/AvIDfx\/qfpqt7fktesggip1133y.webp","width":2500,"height":1875,"credit":"","caption":"<p>A large natural avalanche occurred on May 13th on Whetstone, near Crested Butte. While most avalanches reported during the most recent warm spell were small, loose slides, a few broke deeper in the snowpack and triggered larger slab avalanches like the one shown here.<\/p>","tag":"avalanche","altText":"Large natural avalanche ","dateTaken":"2026-05-14T15:38:24.486Z","isArchived":false},{"id":"8f4b3abc-f70b-459c-92c8-56fd614b96b6","url":"http:\/\/res.cloudinary.com\/dozsqvbas\/image\/upload\/v1778873621\/AvIDfx\/j00ypewnzwcxjolvj1ca.webp","width":2048,"height":1542,"credit":"","caption":"<p>Wet avalanche activity was reported on Peak 1, as observed from the town of Frisco on May 14th. While this particular wet cycle has passed, a forecast of warm and dry weather for later in the week means the threat of wet snow avalanches remains.<\/p>","tag":"avalanche","altText":"avalanche on rocky slope","dateTaken":"2026-05-14T19:33:53.632Z","isArchived":false}]},"dangerRatings":{"days":[{"position":1,"alp":"low","tln":"low","btl":"low","date":"2026-05-20T22:30:00Z"},{"position":2,"alp":"low","tln":"low","btl":"low","date":"2026-05-21T22:30:00Z"},{"position":3,"alp":"low","tln":"low","btl":"low","date":"2026-05-22T22:30:00Z"}]},"avalancheProblems":{"days":[[{"type":"windSlab","aspectElevations":["nw_alp","n_alp","ne_alp"],"likelihood":"unlikely","expectedSize":{"min":"1.0","max":"1.5"}}],[],[]]}},{"id":"d2bb86c3-5a65-4f8d-9c4d-8b881194e905","publicName":"10-11-12-20-21-24-25-37-38-39-4-40-41-42-5-56-6-9","type":"avalancheforecast","polygons":["0FAA4D28-2B56-40A5-A79C-E534A07D98ED","184B517E-9DEF-44B4-9EA8-E45CC96DB776","2CADF229-A5B1-420C-9A58-0D72FE71FDCD","2D929612-B1FD-4AC4-BA12-494ADDCBB442","389E01FC-0600-42E2-82FF-BEF3B23C6105","3C27CD1A-FD13-48B3-B0FF-A5947832FBEB","3F69D3A0-1915-4E8E-AB3F-8F3961B64F10","4481315B-A3B2-430F-AD25-51F077D30A1A","49B9973C-4E52-4B70-A4A9-4718AFB95868","4ADCB7E9-CFDB-462F-B6FB-E787CF1EA2C6","61E64E4C-03E7-433B-B273-22BF6C97E026","6BA1B136-8A8E-4987-83B3-F2DDDDB2DFB7","AD6B1059-5E99-43DC-B921-1DA648F30368","B65805C7-DE42-4F35-BDEE-14E7D6B7605A","E4DE90A5-20FE-4A8F-B297-163BA41C19C9","EEE05A8E-51CF-4AF4-9509-EC7C64D14D20","F9BD77AC-C360-47DF-8195-D16A4C65DE30","FCEB8EE2-B8A0-44E8-ABD9-EEED4EDDDAA7"],"areaId":"7bb543768f9f0eafcf7a9f816c3b47ca956877a8dc6727dd97fac64a9ea2a6d8","forecaster":"Brian Lazar","issueDateTime":"2026-05-19T22:30:00Z","expiryDateTime":"2026-05-20T22:30:00Z","isTranslated":false,"isAutoTranslated":false,"isMultiDay":false,"timezone":"America\/Denver","weatherSummary":{"days":[]},"snowpackSummary":{"days":[]},"avalancheSummary":{"days":[{"date":"2026-05-20T22:30:00Z","content":"<p>The primary concern for Wednesday is avalanches in the recent storm snow. The most dangerous slopes harbor wind-drifted slabs in the alpine, especially below ridgelines and in the tops of gully and couloir features. Stay off very steep slopes if you see cracks forming in the snow or feel stiff layers under your feet.<\/p><p>When sunny skies return, expect the recent snow to quickly get wet and shed off very steep slopes as mostly small, loose wet avalanches. These can be dangerous if they push you into rocks, creeks, or over cliffs.<\/p>"}]},"terrainAndTravelAdvice":{"days":[[],[],[]]},"communication":{"headline":"","sms":""},"media":{"Images":[{"id":"cf39ee8f-e53a-42a8-870b-63ed82d04ddf","url":"http:\/\/res.cloudinary.com\/dozsqvbas\/image\/upload\/v1779137849\/AvIDfx\/dbcs2zni469qfwe6xo5r.webp","width":350,"height":263,"credit":"","caption":"<p>Winds will drift snow onto steep slopes and down-wind of terrain features. You could trigger avalanches like these, in terrain like this, over the next few days. January 10, 2026, near Berthoud Pass.<\/p>","tag":"avalanche","altText":"Looking at avalanche in wind-drifted snow from skin track.","dateTaken":"2026-01-10T21:57:32.022Z","isArchived":false},{"id":"3ade74c6-7592-40cb-b3cc-f8280819c6a8","url":"http:\/\/res.cloudinary.com\/dozsqvbas\/image\/upload\/v1779137637\/AvIDfx\/l5cpogftfky9x6fq0otp.webp","width":350,"height":263,"credit":"","caption":"<p>You might trigger avalanches like this, that break in recently drifted snow. April 16, 2026 near Berthoud Pass.<\/p>","tag":"avalanche","altText":"Small avalanche in drifted snow","dateTaken":"2026-05-16T20:54:00.578Z","isArchived":false},{"id":"3a9dddf2-ec44-489d-a2d5-10250d729884","url":"http:\/\/res.cloudinary.com\/dozsqvbas\/image\/upload\/v1778960323\/AvIDfx\/i3b7jwetml2frw2cuyh1.webp","width":1542,"height":2048,"credit":"","caption":"<p>Wet avalanches remain a concern on Sunday. This photo was taken of recent wet avalanches in the Tenmile Range on Thursday. Although there are less reports of activity, if you find sloppy, wet snow, you can trigger an avalanche.<\/p>","tag":"avalanche","altText":"wet avy","dateTaken":"2026-05-14T19:39:50.852Z","isArchived":false}]},"dangerRatings":{"days":[{"position":1,"alp":"moderate","tln":"low","btl":"low","date":"2026-05-20T22:30:00Z"},{"position":2,"alp":"low","tln":"low","btl":"low","date":"2026-05-21T22:30:00Z"},{"position":3,"alp":"noRating","tln":"noRating","btl":"noRating","date":"2026-05-22T22:30:00Z"}]},"avalancheProblems":{"days":[[{"type":"windSlab","aspectElevations":["ne_alp","n_alp","nw_alp"],"likelihood":"possible","expectedSize":{"min":"1.0","max":"2.0"}},{"type":"wetLoose","aspectElevations":["nw_alp","n_alp","ne_alp","e_alp","se_alp","w_alp","sw_alp","s_alp"],"likelihood":"possible","expectedSize":{"min":"1.0","max":"2.0"}}],[{"type":"wetLoose","aspectElevations":["nw_alp","n_alp","ne_alp","e_alp","se_alp","w_alp","sw_alp","s_alp"],"likelihood":"unlikely","expectedSize":{"min":"1.0","max":"1.5"}}],[]]}}]